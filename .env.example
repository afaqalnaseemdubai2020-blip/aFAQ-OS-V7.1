SMTP_USER=notifications@afaq.com
SMTP_PASS=placeholder

REDIS_URL=redis://localhost:6379/0

FEATURE_FLAGS={"crm":false,"inventory":false,"pricing":false,"market_intelligence":false,"automation":false,"reporting":false,"voice_sales":false,"email_intelligence":false,"employee":false,"scheduling":false,"shopify":false,"agents":false,"content_automation":false,"system_admin":false}

GRACE_WINDOW_MINUTES=15
INACTIVITY_THRESHOLD_MINUTES=15
